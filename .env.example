# ─────────────────────────────────────────────────────────────
# Alıcılar Sigorta — environment variables
# Copy real values into Vercel → Project → Settings → Environment Variables.
# (Do NOT commit real secrets. .env.local is gitignored.)
# ─────────────────────────────────────────────────────────────

# ── Admin login ──
# The password used to log in to /admin
ADMIN_PASSWORD=degistir-guclu-bir-sifre
# Random long string used to sign the admin session cookie
ADMIN_SECRET=uzun-rastgele-bir-anahtar-uret

# ── Web Push (VAPID) — generated for you ──
# Public key is exposed to the browser (NEXT_PUBLIC_)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@alicilarsigorta.com.tr

# ── Vercel KV (Upstash Redis) — auto-added when you create a KV store in Vercel ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Cloudflare R2 (image storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=alicilar-sigorta
# Public URL of the bucket (r2.dev public URL or a custom domain), no trailing slash
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
